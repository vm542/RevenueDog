# RevenueDog configuration. Copy to .env and adjust. Used by docker-compose.yml
# and read directly by the backend (backend/src/config.ts).

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
# development | production | test
# In production the backend refuses to start unless receipt validation is real
# and CORS is locked down (see below) — this prevents shipping a server that
# accepts forged purchases.
NODE_ENV=development

PORT=8787
HOST=0.0.0.0

# SQLite database file. In Docker this lives on the `revenuedog-data` volume.
DATABASE_PATH=./data/revenuedog.db

# Dashboard origin allowed by CORS. Use "*" only for local development;
# production must set a concrete origin, e.g. https://dashboard.example.com
CORS_ORIGIN=*

# Max requests per IP per minute (0 disables). In-memory per instance; for a
# multi-instance deployment, front it with a shared limiter.
RATE_LIMIT_PER_MIN=600

# ---------------------------------------------------------------------------
# Receipt validation
# ---------------------------------------------------------------------------
# trust  = accept the client's claim WITHOUT contacting the store. Local/sandbox
#          testing ONLY — anyone can forge a purchase in this mode.
# apple  = verify StoreKit 2 JWS signatures against Apple.
# google = verify against the Google Play Developer API with a service account.
APPLE_VALIDATION=trust
GOOGLE_VALIDATION=trust

# Apple (when APPLE_VALIDATION=apple):
# APPLE_BUNDLE_ID=com.yourcompany.app
# APPLE_ROOT_CA_PATH=/path/to/AppleRootCA-G3.cer

# Google (when GOOGLE_VALIDATION=google):
# GOOGLE_PACKAGE_NAME=com.yourcompany.app
# GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
